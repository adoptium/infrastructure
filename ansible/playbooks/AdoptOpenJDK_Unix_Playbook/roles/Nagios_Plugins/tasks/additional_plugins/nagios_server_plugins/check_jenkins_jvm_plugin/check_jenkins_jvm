# Nagios exit codes
STATE_OK = 0
STATE_WARNING = 1
STATE_CRITICAL = 2
STATE_UNKNOWN = 3

class JenkinsJVMMonitor:
    def __init__(self, jenkins_url, username=None, api_token=None, metrics_key=None, verify_ssl=True):
        self.jenkins_url = jenkins_url.rstrip('/')
        self.username = username
        self.api_token = api_token
        self.metrics_key = metrics_key
        self.verify_ssl = verify_ssl
        self.use_metrics_key = bool(metrics_key)

    def _make_request(self, endpoint, return_text=False):
        """Make HTTP request to Jenkins API"""
        url = urljoin(self.jenkins_url, endpoint)

        # Create request with authentication if provided
        request = urllib.request.Request(url)
        if self.username and self.api_token and not self.use_metrics_key:
            auth_string = f"{self.username}:{self.api_token}"
            import base64
            auth_bytes = base64.b64encode(auth_string.encode('utf-8'))
            request.add_header("Authorization", f"Basic {auth_bytes.decode('utf-8')}")

        # Handle SSL verification
        context = ssl.create_default_context()
        if not self.verify_ssl:
            context.check_hostname = False
            context.verify_mode = ssl.CERT_NONE

        try:
            with urllib.request.urlopen(request, context=context, timeout=30) as response:
                content = response.read().decode('utf-8')
                if return_text:
                    return content
                return json.loads(content)
        except urllib.error.HTTPError as e:
            raise Exception(f"HTTP Error {e.code}: {e.reason}")
        except urllib.error.URLError as e:
            raise Exception(f"URL Error: {e.reason}")
        except Exception as e:
            raise Exception(f"Request failed: {str(e)}")

    def get_metrics(self):
        """Fetch JVM metrics from Jenkins"""
        try:
            # Determine which endpoint to use
            if self.use_metrics_key:
                endpoint = f'/metrics/{self.metrics_key}/metrics?pretty=true'
            else:
                endpoint = '/metrics/currentUser/metrics?pretty=true'

            data = self._make_request(endpoint)
            return data
        except Exception as e:
            raise Exception(f"Failed to fetch metrics: {str(e)}")

    def get_threads(self):
        """Fetch thread information from Jenkins"""
        try:
            # Determine which endpoint to use
            if self.use_metrics_key:
                endpoint = f'/metrics/{self.metrics_key}/threads'
            else:
                endpoint = '/metrics/currentUser/threads'

            # Thread endpoint returns text, not JSON
            data = self._make_request(endpoint, return_text=True)
            return data
        except Exception as e:
            # Thread endpoint might not be available, return empty string
            return ""

    def parse_memory_metrics(self, metrics):
        """Parse memory-related metrics"""
        memory_data = {}

        # Extract heap memory metrics (note: keys are vm.memory.* not memory.*)
        for key, value in metrics.get('gauges', {}).items():
            if 'vm.memory.heap' in key:
                if 'vm.memory.heap.usage' == key:
                    memory_data['heap_usage_percent'] = value.get('value', 0) * 100
                elif 'vm.memory.heap.used' == key:
                    memory_data['heap_used_bytes'] = value.get('value', 0)
                elif 'vm.memory.heap.max' == key:
                    memory_data['heap_max_bytes'] = value.get('value', 0)
                elif 'vm.memory.heap.committed' == key:
                    memory_data['heap_committed_bytes'] = value.get('value', 0)

            # Extract non-heap memory metrics
            elif 'vm.memory.non-heap' in key:
                if 'vm.memory.non-heap.usage' == key:
                    memory_data['non_heap_usage_percent'] = value.get('value', 0) * 100
                elif 'vm.memory.non-heap.used' == key:
                    memory_data['non_heap_used_bytes'] = value.get('value', 0)
                elif 'vm.memory.non-heap.max' == key:
                    memory_data['non_heap_max_bytes'] = value.get('value', 0)

            # Extract total memory
            elif 'vm.memory.total' in key:
                if 'vm.memory.total.used' == key:
                    memory_data['total_used_bytes'] = value.get('value', 0)
                elif 'vm.memory.total.max' == key:
                    memory_data['total_max_bytes'] = value.get('value', 0)

        return memory_data

    def parse_thread_metrics(self, metrics, thread_dump=""):
        """Parse thread-related metrics from both metrics API and thread dump"""
        thread_data = {}

        # First try to get basic thread metrics from gauges
        for key, value in metrics.get('gauges', {}).items():
            if 'threads' in key:
                if 'threads.count' == key:
                    thread_data['thread_count'] = value.get('value', 0)
                elif 'threads.daemon.count' == key:
                    thread_data['daemon_thread_count'] = value.get('value', 0)
                elif 'threads.deadlock.count' == key:
                    thread_data['deadlock_count'] = value.get('value', 0)
                elif 'threads.blocked.count' == key:
                    thread_data['blocked_thread_count'] = value.get('value', 0)

        # If we have a thread dump, parse detailed thread states
        if thread_dump:
            import re

            # Count total threads (each thread starts with a quote)
            thread_count = len(re.findall(r'^"', thread_dump, re.MULTILINE))
            if thread_count > 0:
                thread_data['thread_count'] = thread_count

            # Count by state
            thread_data['runnable_threads'] = len(re.findall(r'java\.lang\.Thread\.State: RUNNABLE', thread_dump))
            thread_data['waiting_threads'] = len(re.findall(r'java\.lang\.Thread\.State: WAITING', thread_dump))
            thread_data['timed_waiting_threads'] = len(re.findall(r'java\.lang\.Thread\.State: TIMED_WAITING', thread_dump))
            thread_data['blocked_threads'] = len(re.findall(r'java\.lang\.Thread\.State: BLOCKED', thread_dump))
            thread_data['new_threads'] = len(re.findall(r'java\.lang\.Thread\.State: NEW', thread_dump))
            thread_data['terminated_threads'] = len(re.findall(r'java\.lang\.Thread\.State: TERMINATED', thread_dump))

            # Update blocked count if we got it from thread dump
            if thread_data.get('blocked_threads', 0) > 0:
                thread_data['blocked_thread_count'] = thread_data['blocked_threads']

            # Count daemon threads
            daemon_count = len(re.findall(r' daemon ', thread_dump))
            if daemon_count > 0:
                thread_data['daemon_thread_count'] = daemon_count

            # Check for deadlocks
            deadlock_matches = re.findall(r'Found.*deadlock', thread_dump)
            if deadlock_matches:
                thread_data['deadlock_count'] = len(deadlock_matches)

        return thread_data

    def parse_gc_metrics(self, metrics):
        """Parse garbage collection metrics"""
        gc_data = {}

        for key, value in metrics.get('gauges', {}).items():
            if 'gc.' in key and '.time' in key:
                gc_name = key.replace('vm.gc.', '').replace('.time', '')
                gc_data[f'{gc_name}_time_ms'] = value.get('value', 0)
            elif 'gc.' in key and '.count' in key:
                gc_name = key.replace('vm.gc.', '').replace('.count', '')
                gc_data[f'{gc_name}_count'] = value.get('value', 0)

        return gc_data

def bytes_to_mb(bytes_value):
    """Convert bytes to megabytes"""
    return bytes_value / (1024 * 1024)

def bytes_to_gb(bytes_value):
    """Convert bytes to gigabytes"""
    return bytes_value / (1024 * 1024 * 1024)

def check_thresholds(value, warning, critical, name):
    """Check if value exceeds thresholds"""
    messages = []
    status = STATE_OK

    if critical is not None and value >= critical:
        messages.append(f"CRITICAL: {name} is {value:.2f}% (>= {critical}%)")
        status = STATE_CRITICAL
    elif warning is not None and value >= warning:
        messages.append(f"WARNING: {name} is {value:.2f}% (>= {warning}%)")
        status = max(status, STATE_WARNING)
    else:
        messages.append(f"OK: {name} is {value:.2f}%")

    return status, messages
def load_env_config():
    """Load configuration from env.conf if it exists"""
    config = {}
    script_dir = os.path.dirname(os.path.abspath(__file__))
    env_file = os.path.join(script_dir, 'env.conf')

    if os.path.exists(env_file):
        try:
            with open(env_file, 'r') as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith('#') and '=' in line:
                        key, value = line.split('=', 1)
                        # Remove quotes if present
                        value = value.strip().strip('"').strip("'")
                        config[key] = value
        except Exception:
            pass  # Silently ignore errors reading env.conf

    return config


def main():
    # Load environment configuration
    env_config = load_env_config()

    # Get defaults with priority: env vars > env.conf > hardcoded defaults
    default_url = os.environ.get('JENKINS_URL',
                                  env_config.get('JENKINS_URL', DEFAULT_JENKINS_URL))
    default_username = os.environ.get('JENKINS_USER',
                                       env_config.get('USERNAME', DEFAULT_USERNAME))
    default_token = os.environ.get('JENKINS_TOKEN',
                                    env_config.get('API_TOKEN', DEFAULT_API_TOKEN))
    default_metrics_key = os.environ.get('METRICS_KEY',
                                          env_config.get('METRICS_KEY', DEFAULT_METRICS_KEY))
    default_heap_warning = float(os.environ.get('HEAP_WARNING_THRESHOLD',
                                                 env_config.get('HEAP_WARNING_THRESHOLD', str(DEFAULT_HEAP_WARNING))))
    default_heap_critical = float(os.environ.get('HEAP_CRITICAL_THRESHOLD',
                                                  env_config.get('HEAP_CRITICAL_THRESHOLD', str(DEFAULT_HEAP_CRITICAL))))
    default_thread_warning = int(os.environ.get('THREAD_WARNING_THRESHOLD',
                                                 env_config.get('THREAD_WARNING_THRESHOLD', str(DEFAULT_THREAD_WARNING))))
    default_thread_critical = int(os.environ.get('THREAD_CRITICAL_THRESHOLD',
                                                  env_config.get('THREAD_CRITICAL_THRESHOLD', str(DEFAULT_THREAD_CRITICAL))))

    parser = argparse.ArgumentParser(
        description='Nagios plugin to monitor Jenkins JVM health',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Using metrics plugin access key (recommended)
  %(prog)s -H https://jenkins.example.com -k your_metrics_key

  # With username/token authentication
  %(prog)s -H https://jenkins.example.com -u admin -t api_token_here

  # Custom thresholds
  %(prog)s -H https://jenkins.example.com -k key -w 80 -c 90 --thread-warning 500 --thread-critical 800

  # Skip SSL verification (not recommended for production)
  %(prog)s -H https://jenkins.example.com -k key --no-verify-ssl

  # Using environment variables (set in env.conf or shell)
  export JENKINS_URL=https://jenkins.example.com
  export METRICS_KEY=your_metrics_key
  %(prog)s

Environment Variables:
  JENKINS_URL              Jenkins URL
  JENKINS_USER             Jenkins username
  JENKINS_TOKEN            Jenkins API token
  METRICS_KEY              Metrics plugin access key
  HEAP_WARNING_THRESHOLD   Heap memory warning threshold (default: 80)
  HEAP_CRITICAL_THRESHOLD  Heap memory critical threshold (default: 90)
  THREAD_WARNING_THRESHOLD Thread count warning threshold (default: 500)
  THREAD_CRITICAL_THRESHOLD Thread count critical threshold (default: 800)
        """
    )

    # Required arguments (can be provided via environment)
    parser.add_argument('-H', '--host', default=default_url,
                        help='Jenkins URL (e.g., https://jenkins.example.com)')

    # Authentication
    parser.add_argument('-u', '--username', default=default_username,
                        help='Jenkins username for authentication')
    parser.add_argument('-t', '--token', default=default_token,
                        help='Jenkins API token for authentication')
    parser.add_argument('-k', '--metrics-key', default=default_metrics_key,
                        help='Metrics plugin access key (alternative to username/token)')

    # Memory thresholds
    parser.add_argument('-w', '--warning', type=float, default=default_heap_warning,
                        help=f'Warning threshold for heap memory usage percentage (default: {default_heap_warning})')
    parser.add_argument('-c', '--critical', type=float, default=default_heap_critical,
                        help=f'Critical threshold for heap memory usage percentage (default: {default_heap_critical})')

    # Thread thresholds
    parser.add_argument('--thread-warning', type=int, default=default_thread_warning,
                        help=f'Warning threshold for thread count (default: {default_thread_warning})')
    parser.add_argument('--thread-critical', type=int, default=default_thread_critical,
                        help=f'Critical threshold for thread count (default: {default_thread_critical})')

    # Deadlock threshold
    parser.add_argument('--deadlock-critical', type=int, default=1,
                        help='Critical threshold for deadlock count (default: 1)')

    # Blocked threads threshold
    parser.add_argument('--blocked-warning', type=int, default=50,
                        help='Warning threshold for blocked thread count (default: 50)')

    # SSL verification
    parser.add_argument('--no-verify-ssl', action='store_true',
                        help='Disable SSL certificate verification (not recommended)')

    # Verbose output
    parser.add_argument('-v', '--verbose', action='store_true',
                        help='Enable verbose output with detailed metrics')

    args = parser.parse_args()

    # Validate required arguments
    if not args.host:
        print("UNKNOWN: Jenkins URL is required (use -H or set JENKINS_URL)")
        sys.exit(STATE_UNKNOWN)

    try:
        # Initialize monitor
        monitor = JenkinsJVMMonitor(
            jenkins_url=args.host,
            username=args.username,
            api_token=args.token,
            metrics_key=args.metrics_key,
            verify_ssl=not args.no_verify_ssl
        )

        # Fetch metrics
        metrics = monitor.get_metrics()

        # Fetch thread dump for detailed thread information
        thread_dump = monitor.get_threads()

        # Parse metrics
        memory_data = monitor.parse_memory_metrics(metrics)
        thread_data = monitor.parse_thread_metrics(metrics, thread_dump)
        gc_data = monitor.parse_gc_metrics(metrics)

        # Check if we got valid data
        if not memory_data and not thread_data:
            print("UNKNOWN: No metrics data received from Jenkins")
            sys.exit(STATE_UNKNOWN)

        # Initialize status tracking
        overall_status = STATE_OK
        messages = []
        perf_data = []

        # Check heap memory
        if 'heap_usage_percent' in memory_data:
            status, msg = check_thresholds(
                memory_data['heap_usage_percent'],
                args.warning,
                args.critical,
                "Heap memory usage"
            )
            overall_status = max(overall_status, status)
            messages.extend(msg)

            # Add performance data
            heap_used_mb = bytes_to_mb(memory_data.get('heap_used_bytes', 0))
            heap_max_mb = bytes_to_mb(memory_data.get('heap_max_bytes', 0))
            perf_data.append(f"heap_used={heap_used_mb:.2f}MB")
            perf_data.append(f"heap_max={heap_max_mb:.2f}MB")
            perf_data.append(f"heap_usage={memory_data['heap_usage_percent']:.2f}%;{args.warning};{args.critical}")

        # Check non-heap memory
        if 'non_heap_usage_percent' in memory_data:
            non_heap_used_mb = bytes_to_mb(memory_data.get('non_heap_used_bytes', 0))
            perf_data.append(f"non_heap_used={non_heap_used_mb:.2f}MB")
            perf_data.append(f"non_heap_usage={memory_data['non_heap_usage_percent']:.2f}%")

        # Check thread count
        if 'thread_count' in thread_data:
            thread_count = thread_data['thread_count']
            if args.thread_critical and thread_count >= args.thread_critical:
                messages.append(f"CRITICAL: Thread count is {thread_count} (>= {args.thread_critical})")
                overall_status = max(overall_status, STATE_CRITICAL)
            elif args.thread_warning and thread_count >= args.thread_warning:
                messages.append(f"WARNING: Thread count is {thread_count} (>= {args.thread_warning})")
                overall_status = max(overall_status, STATE_WARNING)
            else:
                messages.append(f"OK: Thread count is {thread_count}")

            perf_data.append(f"threads={thread_count};{args.thread_warning};{args.thread_critical}")

            if 'daemon_thread_count' in thread_data:
                perf_data.append(f"daemon_threads={thread_data['daemon_thread_count']}")

        # Check for deadlocks
        if 'deadlock_count' in thread_data:
            deadlock_count = thread_data['deadlock_count']
            if deadlock_count >= args.deadlock_critical:
                messages.append(f"CRITICAL: {deadlock_count} thread deadlock(s) detected!")
                overall_status = STATE_CRITICAL
            perf_data.append(f"deadlocks={deadlock_count}")

        # Check blocked threads
        if 'blocked_thread_count' in thread_data:
            blocked_count = thread_data['blocked_thread_count']
            if blocked_count >= args.blocked_warning:
                messages.append(f"WARNING: {blocked_count} blocked threads (>= {args.blocked_warning})")
                overall_status = max(overall_status, STATE_WARNING)
            perf_data.append(f"blocked_threads={blocked_count}")

        # Add detailed thread state metrics if available
        if 'runnable_threads' in thread_data:
            perf_data.append(f"runnable_threads={thread_data['runnable_threads']}")
        if 'waiting_threads' in thread_data:
            perf_data.append(f"waiting_threads={thread_data['waiting_threads']}")
        if 'timed_waiting_threads' in thread_data:
            perf_data.append(f"timed_waiting_threads={thread_data['timed_waiting_threads']}")
        if 'new_threads' in thread_data:
            perf_data.append(f"new_threads={thread_data['new_threads']}")
        if 'terminated_threads' in thread_data:
            perf_data.append(f"terminated_threads={thread_data['terminated_threads']}")

        # Add GC metrics to performance data
        for gc_name, gc_value in gc_data.items():
            perf_data.append(f"{gc_name}={gc_value}")

        # Build output message
        status_text = {
            STATE_OK: "OK",
            STATE_WARNING: "WARNING",
            STATE_CRITICAL: "CRITICAL",
            STATE_UNKNOWN: "UNKNOWN"
        }

        output = f"Jenkins JVM {status_text[overall_status]} - {' | '.join(messages)}"

        # Add performance data
        if perf_data:
            output += f" | {' '.join(perf_data)}"

        # Add verbose output
        if args.verbose:
            output += "\n\nDetailed Metrics:"
            output += f"\n  Heap Memory: {bytes_to_mb(memory_data.get('heap_used_bytes', 0)):.2f}MB / {bytes_to_mb(memory_data.get('heap_max_bytes', 0)):.2f}MB ({memory_data.get('heap_usage_percent', 0):.2f}%)"
            output += f"\n  Non-Heap Memory: {bytes_to_mb(memory_data.get('non_heap_used_bytes', 0)):.2f}MB"
            output += f"\n  Total Threads: {thread_data.get('thread_count', 0)}"
            output += f"\n  Daemon Threads: {thread_data.get('daemon_thread_count', 0)}"

            # Add detailed thread states if available
            if 'runnable_threads' in thread_data:
                output += "\n  Thread States:"
                output += f"\n    Runnable: {thread_data.get('runnable_threads', 0)}"
                output += f"\n    Waiting: {thread_data.get('waiting_threads', 0)}"
                output += f"\n    Timed Waiting: {thread_data.get('timed_waiting_threads', 0)}"
                output += f"\n    Blocked: {thread_data.get('blocked_threads', 0)}"
                if thread_data.get('new_threads', 0) > 0:
                    output += f"\n    New: {thread_data.get('new_threads', 0)}"
                if thread_data.get('terminated_threads', 0) > 0:
                    output += f"\n    Terminated: {thread_data.get('terminated_threads', 0)}"
            else:
                output += f"\n  Blocked Threads: {thread_data.get('blocked_thread_count', 0)}"

            output += f"\n  Deadlocks: {thread_data.get('deadlock_count', 0)}"

            if gc_data:
                output += "\n  Garbage Collection:"
                for gc_name, gc_value in gc_data.items():
                    output += f"\n    {gc_name}: {gc_value}"

        print(output)
        sys.exit(overall_status)

    except Exception as e:
        print(f"UNKNOWN: {str(e)}")
        sys.exit(STATE_UNKNOWN)

if __name__ == '__main__':
    main()
