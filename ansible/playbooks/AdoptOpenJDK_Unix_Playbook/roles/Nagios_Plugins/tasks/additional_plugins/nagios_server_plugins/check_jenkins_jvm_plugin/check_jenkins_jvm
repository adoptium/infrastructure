# Jenkins URL
DEFAULT_JENKINS_URL = ""  # e.g., "https://jenkins.example.com"

# Authentication - Option 1: Metrics Plugin Access Key (Recommended)
DEFAULT_METRICS_KEY = ""  # e.g., "example-metrics-api-token"

# Authentication - Option 2: Username and API Token
DEFAULT_USERNAME = ""     # e.g., "admin"
DEFAULT_API_TOKEN = ""    # e.g., "123456789exampleapitoken"

# Thresholds
DEFAULT_HEAP_WARNING = 80.0      # Heap memory warning threshold (%)
DEFAULT_HEAP_CRITICAL = 90.0     # Heap memory critical threshold (%)
DEFAULT_THREAD_WARNING = 500     # Thread count warning threshold
DEFAULT_THREAD_CRITICAL = 800    # Thread count critical threshold
DEFAULT_BLOCKED_WARNING = 50     # Blocked threads warning threshold
DEFAULT_DEADLOCK_CRITICAL = 1    # Deadlock count critical threshold

# SSL Verification
DEFAULT_VERIFY_SSL = True        # Set to False to disable SSL verification (not recommended)

# ============================================================================
# END CONFIGURATION
