# Azure Windows Image Updater - Configuration Template
# Copy this file to .env and fill in your values

# Azure Service Principal Credentials
export AZURE_SUBSCRIPTION_ID="your-subscription-id"
export AZURE_TENANT_ID="your-tenant-id"
export AZURE_CLIENT_ID="your-service-principal-client-id"
export AZURE_CLIENT_SECRET="your-service-principal-client-secret"

# Azure Resource Configuration
export AZURE_RESOURCE_GROUP="your-resource-group"
export AZURE_LOCATION="uksouth"  # e.g., eastus, westeurope, uksouth
export AZURE_VNET_NAME="your-vnet-name"
export AZURE_SUBNET_NAME="default"

# Azure Compute Gallery Configuration
export AZURE_GALLERY_NAME="your-gallery-name"
export AZURE_IMAGE_DEFINITION="Windows-2022-x64"  # Single image for test-full-workflow.sh
export AZURE_IMAGE_MULTIPLE="Windows-2022-x64,Windows-2025-x64,Windows-11-x64"  # Comma-separated list for test-full-all-images.sh

# Note: The provisioning script automatically queries the gallery to find the latest version
# of the image definition above. No need to specify AZURE_SOURCE_IMAGE manually.
# The script will use the most recently published version as the base for updates.

# Temporary VM Configuration
export AZURE_VM_SIZE="Standard_D2s_v3"  # VM size for temporary update VM
export AZURE_ADMIN_USERNAME="azureuser"  # Admin username for temporary VM
export AZURE_ADMIN_PASSWORD="YourSecurePassword123!"  # Admin password (min 12 chars, must include uppercase, lowercase, number, special char)

# SSH Keys for Remote Host (administrators_authorized_keys)
# These keys will be deployed to C:\ProgramData\ssh\administrators_authorized_keys
# Add one key per line, each key should be a complete "ssh-rsa ..." or "ssh-ed25519 ..." string
# To add more keys, add additional AZURE_SSH_KEY_N variables (e.g., AZURE_SSH_KEY_4, AZURE_SSH_KEY_5, etc.)
export AZURE_SSH_KEY_1="Example Key"
# Add more keys as needed:
# export AZURE_SSH_KEY_4="ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQ... user@host4"
# export AZURE_SSH_KEY_5="ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQ... user@host5"

# Notes:
# - AZURE_IMAGE_DEFINITION: Single image name for test-full-workflow.sh
# - AZURE_IMAGE_MULTIPLE: Comma-separated list of images for test-full-all-images.sh
# - Latest image version is automatically discovered from the gallery
# - VM_SIZE: Larger sizes (D4s_v3, D8s_v3) will update faster