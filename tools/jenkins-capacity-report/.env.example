# Jenkins Configuration
JENKINS_URL=https://ci.adoptium.net
JENKINS_USERNAME=your_username
JENKINS_API_TOKEN=your_api_token

# Cloud Configuration (optional)
# Path to Jenkins clouds.xml export file
# If not specified, defaults to ./data/clouds.xml.live
CLOUD_CONFIG_FILE=./data/clouds.xml.live

# Metrics Tracking Configuration
# Enable automatic snapshot recording (true/false)
METRICS_AUTO_RECORD=true
# Interval in minutes between automatic snapshots (default: 60)
METRICS_SNAPSHOT_INTERVAL=60

# RBAC Configuration
# Enable role-based access control (true/false)
# When disabled, all API endpoints are accessible without authentication
RBAC_ENABLED=true
# Session timeout in minutes (default: 480 = 8 hours)
SESSION_TIMEOUT_MINUTES=480
# Flask secret key for session management (generate a random string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_secret_key_here_change_this_in_production

# Node Naming Pattern Configuration
# Path to JSON file containing node naming patterns
# If not specified, defaults to ./config/node_patterns.json
# This file defines how to parse node names to extract function, provider, OS, and architecture
NODE_PATTERNS_CONFIG=./config/node_patterns.json